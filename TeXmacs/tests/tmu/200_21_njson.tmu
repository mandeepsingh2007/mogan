    <\folded-io|Scheme] >
      (define sample-json

      \ "{\\"name\\":\\"Goldfish\\",\\"version\\":\\"17.11.26\\",\\"active\\":true,\\"score\\":3.14,\\"nums\\":[1,2,3,4,5],\\"meta\\":{\\"arch\\":\\"x86_64\\",\\"os\\":\\"linux\\"}}")

      \ \ 
    <|folded-io>
      {"name":"Goldfish","version":"17.11.26","active":true,"score":3.14,"nums":[1,2,3,4,5],"meta":{"arch":"x86_64","os":"linux"}}
    </folded-io>

    <\folded-io|Scheme] >
      (define j (string-\<gtr\>njson sample-json))
    <|folded-io>
      (njson-handle 1 . 1)
    <|folded-io>
      \;
    </folded-io>

    <\folded-io|Scheme] >
      (njson? j)
    <|folded-io>
      #t
    </folded-io>

    <\unfolded-io|Scheme] >
      (njson-object? j)
    <|unfolded-io>
      #t
    </unfolded-io>

    <\unfolded-io|Scheme] >
      (njson-array? (njson-ref j "name"))
    <|unfolded-io>
      #f
    </unfolded-io>

    <\unfolded-io|Scheme] >
      (njson-size j)
    <|unfolded-io>
      6
    </unfolded-io>

    <\unfolded-io|Scheme] >
      (njson-empty? (string-\<gtr\>njson "{}"))
    <|unfolded-io>
      #t
    <|unfolded-io>
      \;
    </unfolded-io>

    <\unfolded-io|Scheme] >
      (njson-ref j "meta" "os")
    <|unfolded-io>
      linux
    </unfolded-io>

    <\input|Scheme] >
      \;
    </input>
